KICK_CHANNEL=<channelname>
KICK_USERNAME=<botusername>

# OAuth app credentials (from kick.com developer settings)
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# Redirect URI registered in your Kick app (must match exactly)
KICK_REDIRECT_URI=http://localhost:3000

# Legacy cookie-based auth (fallback if OAuth tokens not present)
KICK_AUTH_TOKEN=
KICK_XSRF_TOKEN=
KICK_SESSION_COOKIE=
KICK_COOKIE_HEADER=

KICK_PUSHER_KEY=
KICK_PUSHER_CLUSTER=
KICK_PUSHER_HOST=
DEBUG_CHAT=1
LOG_CHAT_EVENTS=0
